// BaseScreen.kt.tmpl
// 基础 Screen 骨架模板 —— 适用于所有页面类型的通用起点
// 替换说明：
//   {PACKAGE}   → feature 模块包名，如 com.youlikehub.feature.collection.ui
//   {Name}       → 功能名，如 CollectionList
//   {Title}      → 页面标题（中文），如 收藏列表

package {PACKAGE}

import androidx.compose.foundation.layout.Box
import androidx.compose.foundation.layout.fillMaxSize
import androidx.compose.foundation.layout.padding
import androidx.compose.material3.ExperimentalMaterial3Api
import androidx.compose.material3.Scaffold
import androidx.compose.material3.Text
import androidx.compose.material3.TopAppBar
import androidx.compose.runtime.Composable
import androidx.compose.runtime.getValue
import androidx.compose.ui.Modifier
import androidx.compose.ui.tooling.preview.Preview
import androidx.hilt.navigation.compose.hiltViewModel
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import com.youlikehub.core.ui.components.ErrorContent
import com.youlikehub.core.ui.components.LoadingIndicator

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun {Name}Screen(
    onNavigateBack: () -> Unit,
    modifier: Modifier = Modifier,
    viewModel: {Name}ViewModel = hiltViewModel(),
) {
    val uiState by viewModel.uiState.collectAsStateWithLifecycle()

    {Name}ScreenContent(
        uiState = uiState,
        onNavigateBack = onNavigateBack,
        onRetry = { viewModel.onRetry() },
        modifier = modifier,
    )
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
private fun {Name}ScreenContent(
    uiState: {Name}UiState,
    onNavigateBack: () -> Unit,
    onRetry: () -> Unit,
    modifier: Modifier = Modifier,
) {
    Scaffold(
        topBar = {
            TopAppBar(
                title = { Text("{Title}") },
            )
        },
        modifier = modifier,
    ) { paddingValues ->
        Box(modifier = Modifier.padding(paddingValues).fillMaxSize()) {
            when (uiState) {
                is {Name}UiState.Loading -> LoadingIndicator()
                is {Name}UiState.Error -> ErrorContent(
                    message = uiState.message,
                    onRetry = onRetry,
                )
                is {Name}UiState.Success -> {
                    // TODO: 替换为具体的 Success 内容
                    {Name}Content(
                        data = uiState.data,
                        modifier = Modifier.fillMaxSize(),
                    )
                }
            }
        }
    }
}

@Composable
private fun {Name}Content(
    data: Any,  // TODO: 替换为实际类型
    modifier: Modifier = Modifier,
) {
    // TODO: 实现具体的内容区域
}

// --- Preview ---

@Preview(name = "Loading", showBackground = true)
@Composable
private fun Preview{Name}Loading() {
    YouLikeHubTheme {
        {Name}ScreenContent(
            uiState = {Name}UiState.Loading,
            onNavigateBack = {},
            onRetry = {},
        )
    }
}

@Preview(name = "Error", showBackground = true)
@Composable
private fun Preview{Name}Error() {
    YouLikeHubTheme {
        {Name}ScreenContent(
            uiState = {Name}UiState.Error(message = "网络连接失败"),
            onNavigateBack = {},
            onRetry = {},
        )
    }
}
